# Template for the eufy-security-ws credentials secret.
# Use a SECONDARY Eufy account (share your home to it with admin rights in the
# Eufy app; never log the secondary account into a phone — logins kick other sessions).
#
# To activate Phase 2:
#   1. cp eufy-credentials-secret.yaml.example eufy-credentials-secret.yaml
#   2. Fill in real values below
#   3. source scripts/sops-env.sh && sops --encrypt --in-place clusters/home/apps/home-assistant/eufy/eufy-credentials-secret.yaml
#   4. Uncomment "- ./eufy" in ../kustomization.yaml
#   5. Commit + push, flux reconcile kustomization apps --with-source
apiVersion: v1
kind: Secret
metadata:
  name: eufy-credentials
  namespace: home-assistant
type: Opaque
stringData:
  USERNAME: "secondary-account@example.com"
  PASSWORD: "changeme"
  COUNTRY: "US" # ISO 3166-1 alpha-2, must match the account's registration country
